rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: obtener el perfil del usuario autenticado
    function myProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // ===== COTIZACIONES =====
    // Cualquiera puede crear (formulario público de cotización)
    // Admins: lectura y escritura completa
    // Partners: solo pueden leer las cotizaciones que tienen su código referral
    match /cotizaciones/{docId} {
      allow create: if true;

      allow read: if request.auth != null && (
        myProfile().isAdmin == true ||
        (myProfile().isPartner == true &&
         resource.data.referralCodeUsed == myProfile().partnerCode)
      );

      allow update, delete: if request.auth != null &&
        myProfile().isAdmin == true;
    }

    // ===== USUARIOS / PERFILES =====
    // El propio usuario puede leer su perfil
    // Solo admins pueden escribir perfiles de usuario
    match /users/{userId} {
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        myProfile().isAdmin == true
      );
      allow write: if request.auth != null && (
        request.auth.uid == userId ||
        myProfile().isAdmin == true
      );
    }

    // ===== CLIENTES =====
    // Solo admins pueden gestionar clientes y sus pagos
    match /clientes/{clienteId} {
      allow read, write: if request.auth != null &&
        myProfile().isAdmin == true;
    }
    match /clientes/{clienteId}/pagos/{pagoId} {
      allow read, write: if request.auth != null &&
        myProfile().isAdmin == true;
    }
  }
}
