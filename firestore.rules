rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===== COTIZACIONES =====
    // Cualquiera puede crear una cotización (formulario público)
    // Solo usuarios autenticados pueden leer/actualizar/eliminar
    match /cotizaciones/{docId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // ===== USUARIOS / PERFILES =====
    // El propio usuario puede leer su perfil
    // Solo admins (marcados en Firestore) pueden crear/modificar perfiles
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null;
    }
  }
}
